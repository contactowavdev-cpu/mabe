---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumbs from './Breadcrumbs.astro'
import CTA from './CTA.astro'
import { SITE } from '../data/site'
import type { CommercialPage as PageData } from '../data/commercial'

interface Props {
  page: PageData
}

const { page } = Astro.props
const sectionLabel = page.section === 'servicios' ? 'Servicios' : 'Soluciones'
const canonical = `${SITE.url}/${page.section}/${page.slug}/`
const whatsapp = `${SITE.whatsapp}?text=${encodeURIComponent(`Hola WavDev, quiero información sobre ${page.shortTitle}.`)}`
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${canonical}#service`,
    name: page.title,
    description: page.description,
    url: canonical,
    areaServed: { '@type': 'Country', name: 'Guatemala' },
    provider: { '@id': `${SITE.url}/#organization` },
    serviceType: page.keyword,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/` },
      { '@type': 'ListItem', position: 2, name: sectionLabel, item: `${SITE.url}/${page.section}/` },
      { '@type': 'ListItem', position: 3, name: page.shortTitle, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: page.faqs.map(([question, answer]) => ({
      '@type': 'Question',
      name: question,
      acceptedAnswer: { '@type': 'Answer', text: answer },
    })),
  },
]
---

<BaseLayout title={`${page.title} | WavDev`} description={page.description} canonical={canonical} schema={schema}>
  <header class="service-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: sectionLabel }, { label: page.shortTitle }]} />
      <span class="eyebrow">{page.eyebrow}</span>
      <h1>{page.title}</h1>
      <p class="lead">{page.description}</p>
      <div class="button-row">
        <a class="button button-primary" href={`/contacto/?servicio=${encodeURIComponent(page.shortTitle)}`} data-cta="quote">Solicitar diagnóstico</a>
        <a class="button button-secondary" href={whatsapp} target="_blank" rel="noopener noreferrer">Consultar por WhatsApp</a>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container split">
      <article class="prose">
        {page.intro.map((paragraph) => <p class="lead">{paragraph}</p>)}
        {page.sections.map((section) => (
          <section>
            <h2>{section.heading}</h2>
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </section>
        ))}

        <section>
          <h2>Cómo implementamos esta solución</h2>
          {page.process.map(([title, description], index) => (
            <div>
              <h3>{String(index + 1).padStart(2, '0')}. {title}</h3>
              <p>{description}</p>
            </div>
          ))}
        </section>

        <section>
          <h2>Integraciones habituales</h2>
          <p>La selección final depende de las APIs, permisos y condiciones de cada proveedor.</p>
          <ul>
            {page.integrations.map((integration) => <li>{integration}</li>)}
          </ul>
        </section>

        <section class="faq">
          <h2>Preguntas frecuentes</h2>
          {page.faqs.map(([question, answer]) => (
            <details>
              <summary>{question}<span aria-hidden="true">+</span></summary>
              <p>{answer}</p>
            </details>
          ))}
        </section>
      </article>

      <aside class="card card-body aside-card">
        <span class="eyebrow">Enfoque</span>
        <h2 class="aside-title">Resultados operativos antes que funciones aisladas</h2>
        <h3>Beneficios</h3>
        <ul class="check-list">
          {page.benefits.map((item) => <li>{item}</li>)}
        </ul>
        <h3 class="aside-subtitle">Casos de uso</h3>
        <ul class="check-list">
          {page.useCases.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="section related-section">
    <div class="container">
      <span class="eyebrow">Continúa investigando</span>
      <h2>Servicios, casos y recursos relacionados</h2>
      <div class="grid grid-3">
        {page.related.map((href) => (
          <a class="card card-body related-link" href={href}>
            <span>{href.includes('/recursos/') ? 'Recurso' : href.includes('/casos-de-exito/') ? 'Caso de éxito' : 'Solución relacionada'}</span>
            <strong>{href.split('/').filter(Boolean).at(-1)?.replaceAll('-', ' ')}</strong>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA service={page.shortTitle} />
</BaseLayout>
