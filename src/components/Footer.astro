---
import { SITE } from '../data/site'
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid footer-grid-wide">
      <div>
        <a class="brand" href="/">
          <img src="/images/wavdev.webp" width="38" height="38" alt="" />
          <span>WavDev</span>
        </a>
        <p class="muted">Desarrollo de software y soluciones tecnológicas para empresas de Guatemala.</p>
        <p class="muted">Áreas atendidas: {SITE.serviceAreas.join(', ')}.</p>
      </div>
      <div>
        <h3>Servicios</h3>
        <div class="footer-links">
          <a href="/servicios/desarrollo-web-guatemala/">Desarrollo web</a>
          <a href="/servicios/sistemas-a-la-medida/">Sistemas a la medida</a>
          <a href="/servicios/crm-para-empresas/">CRM</a>
          <a href="/servicios/automatizacion-de-procesos/">Automatización</a>
          <a href="/servicios/">Todos los servicios</a>
        </div>
      </div>
      <div>
        <h3>Soluciones</h3>
        <div class="footer-links">
          <a href="/soluciones/crm-para-equipos-de-ventas/">Equipos de ventas</a>
          <a href="/soluciones/software-para-inmobiliarias/">Inmobiliarias</a>
          <a href="/soluciones/sistemas-de-recursos-humanos/">Recursos humanos</a>
          <a href="/soluciones/automatizar-procesos-con-excel/">Procesos con Excel</a>
        </div>
      </div>
      <div>
        <h3>Empresa</h3>
        <div class="footer-links">
          <a href="/casos-de-exito/">Casos de éxito</a>
          <a href="/recursos/">Recursos</a>
          <a href="/nosotros/">Nosotros</a>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
          <a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} WavDev. Todos los derechos reservados.</span>
      <span><a href="/privacidad/">Privacidad</a> · <a href="/terminos/">Términos</a></span>
    </div>
  </div>
</footer>
