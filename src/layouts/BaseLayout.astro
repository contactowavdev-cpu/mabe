---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { SITE } from '../data/site'

interface Props {
  title: string
  description: string
  canonical?: string
  image?: string
  imageAlt?: string
  type?: 'website' | 'article'
  schema?: Record<string, unknown> | Array<Record<string, unknown>>
  noindex?: boolean
}

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, SITE.url).toString(),
  image = `${SITE.url}/images/wavdev-social.png`,
  imageAlt = 'WavDev, desarrollo de software en Guatemala',
  type = 'website',
  schema,
  noindex = false,
} = Astro.props

const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION
const bingVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION
const defaultSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  url: canonical,
  name: title,
  description,
  isPartOf: { '@id': `${SITE.url}/#website` },
  inLanguage: 'es-GT',
}
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  url: SITE.url,
  logo: `${SITE.url}/images/logo.webp`,
  email: SITE.email,
  telephone: SITE.phone,
  sameAs: [SITE.linkedin, SITE.youtube, SITE.instagram, SITE.twitter].filter(Boolean),
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  name: SITE.name,
  url: SITE.url,
  inLanguage: 'es-GT',
  publisher: { '@id': `${SITE.url}/#organization` },
}

const schemas = Array.isArray(schema) ? schema : [schema || defaultSchema]
const schemaItems: Record<string, unknown>[] = [organizationSchema, websiteSchema, ...schemas]
const schemaKey = (item: Record<string, unknown>, index: number) =>
  String(item['@id'] || `${item['@type']}:${item.url || item.name || index}`)
const schemasCombined = schemaItems.filter((item, index, items) => {
  const key = schemaKey(item, index)
  return items.findIndex((candidate, candidateIndex) => {
    return schemaKey(candidate, candidateIndex) === key
  }) === index
})

---

<!doctype html>
<html lang="es-GT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#ffffff" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large'} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/webp" href="/images/logo.webp" />
    {googleVerification && <meta name="google-site-verification" content={googleVerification} />}
    {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}

    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content="es_GT" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={imageAlt} />

    {schemasCombined.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}

    {
      gaId && (
        <>
          <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', gaId, { anonymize_ip: true });
          </script>
        </>
      )
    }
    <script is:inline>
      window.trackWavDevEvent = function (eventName, parameters) {
        if (typeof window.gtag === 'function') {
          window.gtag('event', eventName, parameters || {});
        }
      };
      document.addEventListener('click', function (event) {
        var link = event.target.closest('a');
        if (!link) return;
        var href = link.getAttribute('href') || '';
        var parameters = {
          link_url: href,
          link_text: (link.textContent || '').trim(),
          page_path: window.location.pathname,
          service: link.dataset.service || undefined
        };
        if (href.includes('wa.me')) window.trackWavDevEvent('whatsapp_click', parameters);
        if (href.startsWith('tel:')) window.trackWavDevEvent('phone_click', parameters);
        if (href.startsWith('mailto:')) window.trackWavDevEvent('email_click', parameters);
        if (link.dataset.cta === 'quote') window.trackWavDevEvent('quote_click', parameters);
      });
    </script>
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <Header />
    <main id="contenido">
      <slot />
    </main>
    <Footer />
  </body>
</html>
