---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { SITE } from '../data/site'

interface Props {
  title: string
  description: string
  canonical?: string
  image?: string
  imageAlt?: string
  type?: 'website' | 'article'
  schema?: Record<string, unknown> | Array<Record<string, unknown>>
  noindex?: boolean
}

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, SITE.url).toString(),
  image = `${SITE.url}/images/wavdev-social.png`,
  imageAlt = 'WavDev, desarrollo de software en Guatemala',
  type = 'website',
  schema,
  noindex = false,
} = Astro.props

const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID
const defaultSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  url: canonical,
  name: title,
  description,
  isPartOf: { '@id': `${SITE.url}/#website` },
  inLanguage: 'es-GT',
}
const schemas = Array.isArray(schema) ? schema : [schema || defaultSchema]
---

<!doctype html>
<html lang="es-GT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#040c10" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large'} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/webp" href="/images/logo.webp" />

    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content="es_GT" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={imageAlt} />

    {schemas.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}

    {
      gaId && (
        <>
          <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', gaId, { anonymize_ip: true });
          </script>
        </>
      )
    }
    <script is:inline>
      window.trackWavDevEvent = function (eventName, parameters) {
        if (typeof window.gtag === 'function') {
          window.gtag('event', eventName, parameters || {});
        }
      };
      document.addEventListener('click', function (event) {
        var link = event.target.closest('a');
        if (!link) return;
        var href = link.getAttribute('href') || '';
        if (href.includes('wa.me')) window.trackWavDevEvent('whatsapp_click', { link_url: href });
        if (href.startsWith('tel:')) window.trackWavDevEvent('phone_click', { link_url: href });
        if (href.startsWith('mailto:')) window.trackWavDevEvent('email_click', { link_url: href });
      });
    </script>
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <Header />
    <main id="contenido">
      <slot />
    </main>
    <Footer />
  </body>
</html>
