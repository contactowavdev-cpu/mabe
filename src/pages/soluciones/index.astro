---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import { COMMERCIAL_PAGES } from '../../data/commercial'
import { GROWTH_PAGES } from '../../data/growth'

const solutions = [
  ...GROWTH_PAGES.filter((page) => page.section === 'soluciones'),
  ...COMMERCIAL_PAGES.filter((page) => page.section === 'soluciones'),
]
const description = 'Soluciones POS, ERP, inventarios, CRM, software inmobiliario y automatización para empresas de Guatemala.'
---

<BaseLayout title="Soluciones de software por proceso e industria | WavDev" description={description}>
  <header class="service-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Soluciones' }]} />
      <span class="eyebrow">Soluciones por necesidad</span>
      <h1>Software diseñado alrededor de procesos empresariales</h1>
      <p class="lead">Explora soluciones para ventas, inventario, caja, gestión empresarial, recursos humanos y procesos que todavía dependen de archivos separados.</p>
    </div>
  </header>
  <section class="section">
    <div class="container grid grid-2">
      {solutions.map((page) => (
        <article class="card card-body service-card">
          <span class="eyebrow">{page.eyebrow}</span>
          <h2 class="card-title">{page.shortTitle}</h2>
          <p class="muted">{page.description}</p>
          <a href={`/soluciones/${page.slug}/`}>Explorar solución →</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
