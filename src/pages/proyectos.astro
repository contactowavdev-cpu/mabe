---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import CTA from '../components/CTA.astro'
import ResponsiveImage from '../components/ResponsiveImage.astro'
import { PROJECTS } from '../data/site'

const caseSlugs = ['crm-automatizacion-ventas', 'plataforma-gestion-inmobiliaria', 'sistema-reclutamiento-rrhh']
const description = 'Conoce proyectos y casos documentados de CRM, plataformas inmobiliarias y sistemas empresariales desarrollados por WavDev.'
---

<BaseLayout title="Proyectos y casos de software empresarial | WavDev" description={description}>
  <header class="service-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Proyectos' }]} />
      <span class="eyebrow">Portafolio y evidencia</span>
      <h1>Proyectos digitales pensados para resolver problemas reales</h1>
      <p class="lead">Documentamos el contexto, la solución y la evidencia disponible. No publicamos métricas o testimonios sin autorización verificable.</p>
      <div class="button-row">
        <a class="button button-primary" href="/casos-de-exito/">Ver todos los casos</a>
      </div>
    </div>
  </header>
  <section class="section">
    <div class="container grid">
      {PROJECTS.map((project, index) => (
        <article class="card split project-row">
          <ResponsiveImage src={project.image} alt={project.alt} sizes="(max-width: 860px) 100vw, 50vw" />
          <div class="card-body">
            <span class="eyebrow">{project.category}</span>
            <h2>{project.name}</h2>
            <p class="lead">{project.description}</p>
            <p class="muted">El caso presenta las funciones demostrables y el marco de medición recomendado, sin inventar resultados comerciales.</p>
            <a class="button button-secondary" href={`/casos-de-exito/${caseSlugs[index]}/`}>Leer caso completo</a>
          </div>
        </article>
      ))}
    </div>
  </section>
  <CTA />
</BaseLayout>
