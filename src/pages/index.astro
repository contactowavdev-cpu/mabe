---
import BaseLayout from '../layouts/BaseLayout.astro'
import CTA from '../components/CTA.astro'
import ResponsiveImage from '../components/ResponsiveImage.astro'
import { PROJECTS, SERVICES, SITE } from '../data/site'

const title = 'Desarrollo de Software y Sistemas a la Medida en Guatemala | WavDev'
const description =
  'Desarrollamos páginas web, sistemas a la medida, CRM y automatizaciones para empresas y PYMES en Guatemala. Solicita una cotización.'
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': ['Organization', 'LocalBusiness'],
    '@id': `${SITE.url}/#organization`,
    name: SITE.name,
    url: SITE.url,
    logo: `${SITE.url}/images/logo.webp`,
    image: `${SITE.url}/images/wavdev-social.png`,
    description,
    email: SITE.email,
    telephone: SITE.phone,
    priceRange: '$$',
    areaServed: SITE.serviceAreas.map((name) => ({ '@type': 'City', name })),
    address: { '@type': 'PostalAddress', addressCountry: 'GT' },
    sameAs: [SITE.linkedin],
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'sales',
      email: SITE.email,
      telephone: SITE.phone,
      availableLanguage: ['es'],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${SITE.url}/#website`,
    name: SITE.name,
    url: SITE.url,
    inLanguage: 'es-GT',
    publisher: { '@id': `${SITE.url}/#organization` },
  },
]
---

<BaseLayout title={title} description={description} canonical={`${SITE.url}/`} schema={schema}>
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-orbit" aria-hidden="true"></div>
      <div class="hero-copy">
        <span class="eyebrow">Software que mueve empresas</span>
        <h1>Software para empresas de Guatemala que <span class="gradient-text">sí hace avanzar.</span></h1>
        <p class="lead">
          Diseñamos páginas web, sistemas empresariales, CRM y automatizaciones para que las empresas de Guatemala vendan mejor, trabajen con claridad y puedan crecer sin sumar caos.
        </p>
        <div class="button-row">
          <a class="button button-primary" href="/contacto/">Evaluar mi proyecto →</a>
          <a class="button button-secondary" href="#servicios">Explorar servicios</a>
        </div>
        <div class="stat-strip" aria-label="Enfoque de WavDev">
          <div class="stat"><strong>01</strong><span>Diagnóstico antes de desarrollar</span></div>
          <div class="stat"><strong>02</strong><span>Entregas incrementales y verificables</span></div>
          <div class="stat"><strong>03</strong><span>Medición después del lanzamiento</span></div>
        </div>
      </div>
      <div class="hero-console" aria-label="Vista conceptual de una operación empresarial conectada">
        <div class="console-bar">
          <div class="console-dots" aria-hidden="true"><span></span><span></span><span></span></div>
          <span>WavDev / centro operativo</span>
        </div>
        <div class="console-panel">
          <div class="console-heading">
            <strong>Tu operación, conectada</strong>
            <span class="status-pill">EN LÍNEA</span>
          </div>
          <div class="console-grid">
            <div class="console-metric"><span>Ventas y clientes</span><strong>CRM + WhatsApp</strong></div>
            <div class="console-metric"><span>Control operativo</span><strong>ERP + inventario</strong></div>
            <div class="console-metric"><span>Canal digital</span><strong>Web + e-commerce</strong></div>
            <div class="console-metric"><span>Trabajo repetitivo</span><strong>Automatización</strong></div>
          </div>
          <div class="console-activity">Información lista para decidir, no para buscar.</div>
          <div class="console-activity">Procesos pensados para las personas que los usan.</div>
        </div>
      </div>
    </div>
  </section>

  <div class="capability-rail" aria-label="Capacidades de WavDev">
    <div class="capability-track">
      <span>Desarrollo web</span><span>Sistemas a la medida</span><span>CRM</span><span>ERP</span><span>POS</span><span>Automatización</span><span>E-commerce</span>
      <span aria-hidden="true">Desarrollo web</span><span aria-hidden="true">Sistemas a la medida</span><span aria-hidden="true">CRM</span><span aria-hidden="true">ERP</span><span aria-hidden="true">POS</span><span aria-hidden="true">Automatización</span><span aria-hidden="true">E-commerce</span>
    </div>
  </div>

  <section class="section" id="servicios">
    <div class="container">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Servicios</span>
          <h2>Tecnología con una tarea clara.</h2>
        </div>
        <p class="lead">Captar oportunidades, centralizar información, mejorar ventas o reducir trabajo repetitivo. Sin software decorativo.</p>
      </div>
      <div class="grid grid-2">
        {SERVICES.map((service, index) => (
          <article class="card card-body service-card">
            <span class="number">0{index + 1}</span>
            <h3>{service.shortTitle}</h3>
            <p class="muted">{service.description}</p>
            <a href={`/servicios/${service.slug}/`}>Ver {service.shortTitle.toLowerCase()} →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section accent-section">
    <div class="container split">
      <div>
        <span class="eyebrow">Forma de trabajo</span>
        <h2>Menos promesas abstractas. Más decisiones verificables.</h2>
        <p class="lead">Comenzamos por el problema y las personas que usarán la solución. Definimos alcance, riesgos y criterios de aceptación antes de convertir una idea en meses de desarrollo.</p>
      </div>
      <div class="grid method-grid">
        {[
          ['Comprender', 'Documentamos objetivos, procesos, usuarios y restricciones.'],
          ['Priorizar', 'Seleccionamos la primera entrega que produzca valor y reduzca incertidumbre.'],
          ['Construir', 'Desarrollamos por etapas con demostraciones y validación frecuente.'],
          ['Medir', 'Observamos uso, rendimiento y resultados para decidir la siguiente mejora.'],
        ].map(([heading, text]) => (
          <article class="card card-body method-card">
            <h3>{heading}</h3>
            <p class="muted">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">Proyectos</span>
      <h2>Soluciones que muestran cómo pensamos</h2>
      <p class="lead">Presentamos ejemplos del tipo de experiencia y problemas que podemos abordar. Las métricas se publican únicamente cuando pueden verificarse con el cliente.</p>
      <div class="grid grid-3" style="margin-top:2rem;">
        {PROJECTS.map((project) => (
          <article class="card" style="overflow:hidden;">
            <ResponsiveImage src={project.image} alt={project.alt} sizes="(max-width: 860px) 100vw, 33vw" />
            <div class="card-body">
              <span class="eyebrow">{project.category}</span>
              <h3>{project.name}</h3>
              <p class="muted">{project.description}</p>
            </div>
          </article>
        ))}
      </div>
      <div class="button-row" style="margin-top:2rem;">
        <a class="button button-secondary" href="/proyectos/">Ver proyectos</a>
      </div>
    </div>
  </section>

  <section class="section" style="border-top:1px solid var(--line);">
    <div class="container split">
      <div>
        <span class="eyebrow">Presencia local</span>
        <h2>Servicios tecnológicos para empresas de Guatemala</h2>
      </div>
      <div class="prose">
        <p>Atendemos proyectos en Ciudad de Guatemala, Cobán, Jutiapa y otras ubicaciones mediante colaboración remota. Estas ciudades se presentan como áreas de servicio, no como oficinas físicas.</p>
        <p>Trabajamos con empresas que necesitan una página profesional, ordenar su operación comercial o transformar procesos dispersos en software confiable.</p>
      </div>
    </div>
  </section>

  <section class="section" style="border-top:1px solid var(--line);">
    <div class="container">
      <span class="eyebrow">Soluciones especializadas</span>
      <h2>Explora por proceso e industria</h2>
      <div class="grid grid-2" style="margin-top:2rem;">
        <a class="card card-body related-link" href="/soluciones/sistema-pos-guatemala/"><span>Comercios</span><strong>Sistema POS, caja y sucursales</strong></a>
        <a class="card card-body related-link" href="/soluciones/software-inventarios-guatemala/"><span>Inventarios</span><strong>Bodegas, compras y existencias</strong></a>
        <a class="card card-body related-link" href="/soluciones/erp-para-pymes-guatemala/"><span>Gestión empresarial</span><strong>ERP modular para PYMES</strong></a>
        <a class="card card-body related-link" href="/soluciones/crm-ventas-guatemala/"><span>Ventas</span><strong>CRM, cotizaciones y seguimiento</strong></a>
        <a class="card card-body related-link" href="/servicios/desarrollo-ecommerce-guatemala/"><span>Comercio electrónico</span><strong>Tiendas conectadas con inventario</strong></a>
        <a class="card card-body related-link" href="/soluciones/automatizar-procesos-con-excel/"><span>Operaciones</span><strong>Automatización de procesos con Excel</strong></a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div>
        <span class="eyebrow">Recursos</span>
        <h2>Decisiones tecnológicas con más contexto</h2>
        <p class="lead">Publicamos guías sobre costos, selección de herramientas, CRM y automatización basadas en preguntas reales de empresas.</p>
        <a class="button button-secondary" href="/recursos/">Ver recursos</a>
      </div>
      <div class="card card-body">
        <h3>Guías iniciales</h3>
        <div class="footer-links">
          <a href="/recursos/cuanto-cuesta-pagina-web-profesional-guatemala/">Cuánto cuesta una página web profesional</a>
          <a href="/recursos/sistema-a-la-medida-vs-erp/">Sistema a la medida vs. ERP</a>
          <a href="/recursos/como-elegir-crm-empresa-guatemala/">Cómo elegir un CRM</a>
          <a href="/recursos/como-automatizar-procesos-que-dependen-de-excel/">Cómo automatizar procesos con Excel</a>
          <a href="/recursos/como-elegir-sistema-pos-guatemala/">Cómo elegir un sistema POS</a>
          <a href="/recursos/como-controlar-inventario-varias-bodegas/">Controlar inventario en varias bodegas</a>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
