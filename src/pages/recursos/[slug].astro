---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import CTA from '../../components/CTA.astro'
import ResponsiveImage from '../../components/ResponsiveImage.astro'
import { SITE } from '../../data/site'

export const prerender = true

export async function getStaticPaths() {
  const entries = await getCollection('resources', ({ data }) => !data.draft)
  return entries.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }))
}

const { entry } = Astro.props
const { Content, headings } = await render(entry)
const canonical = `${SITE.url}/recursos/${entry.data.slug}/`
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: entry.data.title,
    description: entry.data.description,
    image: `${SITE.url}${entry.data.featuredImage}`,
    datePublished: entry.data.publishDate.toISOString(),
    dateModified: entry.data.updatedDate.toISOString(),
    author: { '@type': 'Organization', name: entry.data.author, url: SITE.url },
    publisher: { '@id': `${SITE.url}/#organization` },
    mainEntityOfPage: canonical,
    inLanguage: 'es-GT',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/` },
      { '@type': 'ListItem', position: 2, name: 'Recursos', item: `${SITE.url}/recursos/` },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: canonical },
    ],
  },
]
---

<BaseLayout title={`${entry.data.title} | WavDev`} description={entry.data.description} canonical={canonical} image={`${SITE.url}${entry.data.featuredImage}`} type="article" schema={schema}>
  <article>
    <header class="service-hero">
      <div class="container">
        <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Recursos', href: '/recursos/' }, { label: entry.data.category }]} />
        <span class="eyebrow">{entry.data.category}</span>
        <h1>{entry.data.title}</h1>
        <p class="lead">{entry.data.description}</p>
        <div class="content-meta-row">
          <span>Por {entry.data.author}</span>
          <span>Revisado por {entry.data.reviewer}</span>
          <time datetime={entry.data.updatedDate.toISOString()}>Actualizado {entry.data.updatedDate.toLocaleDateString('es-GT', { dateStyle: 'long' })}</time>
        </div>
      </div>
    </header>

    <section class="section">
      <div class="container article-layout">
        <div>
          <ResponsiveImage src={entry.data.featuredImage} alt={`Ilustración de ${entry.data.title}`} loading="eager" fetchpriority="high" sizes="(max-width: 900px) 100vw, 760px" />
          <div class="prose article-prose">
            <Content />
          </div>
          {entry.data.sources.length > 0 && (
            <section class="prose sources">
              <h2>Fuentes consultadas</h2>
              <ul>
                {entry.data.sources.map((source) => <li><a href={source} target="_blank" rel="noopener noreferrer">{new URL(source).hostname}</a></li>)}
              </ul>
            </section>
          )}
        </div>
        <aside class="card card-body article-toc" aria-label="Tabla de contenido">
          <span class="eyebrow">En esta guía</span>
          <nav>
            {headings.filter((heading) => heading.depth === 2).map((heading) => <a href={`#${heading.slug}`}>{heading.text}</a>)}
          </nav>
        </aside>
      </div>
    </section>
  </article>
  <CTA service={entry.data.service} />
</BaseLayout>
