---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Breadcrumbs from '../../components/Breadcrumbs.astro'
import ResponsiveImage from '../../components/ResponsiveImage.astro'

const resources = (await getCollection('resources', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
const description = 'Guías prácticas de WavDev sobre desarrollo web, sistemas a la medida, CRM y automatización para empresas de Guatemala.'
---

<BaseLayout title="Recursos sobre software empresarial y desarrollo web | WavDev" description={description}>
  <header class="service-hero">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Recursos' }]} />
      <span class="eyebrow">Centro de recursos</span>
      <h1>Guías para tomar mejores decisiones tecnológicas</h1>
      <p class="lead">Contenido revisado por el equipo de WavDev para comparar soluciones, preparar proyectos y medir resultados sin depender de promesas abstractas.</p>
    </div>
  </header>
  <section class="section">
    <div class="container grid grid-2">
      {resources.map((entry) => (
        <article class="card resource-card">
          <ResponsiveImage src={entry.data.featuredImage} alt="" sizes="(max-width: 860px) 100vw, 50vw" />
          <div class="card-body">
            <span class="eyebrow">{entry.data.category}</span>
            <h2 class="card-title"><a href={`/recursos/${entry.data.slug}/`}>{entry.data.title}</a></h2>
            <p class="muted">{entry.data.description}</p>
            <p class="content-meta">Actualizado el {entry.data.updatedDate.toLocaleDateString('es-GT', { dateStyle: 'long' })}</p>
            <a class="text-link" href={`/recursos/${entry.data.slug}/`}>Leer guía →</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
