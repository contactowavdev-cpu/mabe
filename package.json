{
  "name": "mabe",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:pwa",
    "dev:pwa": "npm run dev -w @mabe/ordenes-pwa",
    "dev:api": "npm run start:dev -w @mabe/api",
    "build:pwa": "npm run build -w @mabe/ordenes-pwa",
    "build:api": "npm run build -w @mabe/api",
    "build": "npm run build:api",
    "build:all": "npm run build:api && npm run build:pwa",
    "start": "npm run start -w @mabe/api",
    "preview": "npm run preview -w @mabe/ordenes-pwa",
    "prisma:generate": "npm run prisma:generate -w @mabe/api"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "vite": "7.3.5"
  }
}
